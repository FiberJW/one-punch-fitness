{
  "expo": {
    "name": "One Punch Fitness",
    "description": "A \"One Punch Man\"-inspired workout app!",
    "slug": "one-punch-fitness",
    "version": "0.5.1",
    "orientation": "portrait",
    "scheme": "onepunchfitness",
    "primaryColor": "#651FFF",
    "userInterfaceStyle": "dark",
    "icon": "./assets/expo-icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.jwheatley.opf",
      "icon": "./assets/ios-icon.png"
    },
    "android": {
      "package": "co.jwheatley.opf",
      "icon": "./assets/android-icon.png"
    },
    "assetBundlePatterns": ["assets/**/*"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#651FFF"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/InterUI-Regular.ttf",
            "./assets/fonts/InterUI-Medium.ttf",
            "./assets/fonts/InterUI-Bold.ttf",
            "./assets/fonts/InterUI-Black.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
